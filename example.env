# ===========================================
# Intelligent Task Orchestrator - Environment
# ===========================================
# Copy this file to .env and fill in your values
# cp example.env .env

# ------------------------------------------
# NVIDIA NIM API Configuration
# ------------------------------------------
# Your NVIDIA NIM API key (required)
# Get one at: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA NIM API base URL (optional, default shown)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# LLM model to use (optional, default shown)
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# SQLite connection string (optional, default shown)
DATABASE_URL=sqlite:///./orchestrator.db

# ------------------------------------------
# Validation Thresholds
# ------------------------------------------
# Minimum average score across all 10 metrics to pass (0-100)
VALIDATION_AVG_THRESHOLD=95

# Minimum score for any individual metric to pass (0-100)
VALIDATION_MIN_THRESHOLD=90

# ------------------------------------------
# Replanning Configuration
# ------------------------------------------
# Max number of LLM replanning attempts before giving up
MAX_REPLAN_RETRIES=3

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# Backend host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend dev server port
FRONTEND_PORT=3000
